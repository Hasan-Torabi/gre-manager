main_menu() {
  require_root; ensure_dirs
  while true; do
    menu_header
    echo "0) GRE pre-check between two servers"
    echo "1) Create/setup a GRE tunnel"
    echo "2) Delete/remove a tunnel"
    echo "3) Edit a managed tunnel"
    echo "4) View tunnel logs/status"
    echo "5) Check tunnel health"
    echo "6) Show detected tunnel details"
    echo "7) Manage MSS clamp"
    echo "8) Manage rp_filter"
    echo "9) Manage watchdog"
    echo "10) Install manager locally/global"
    echo "11) Update manager from GitHub"
    echo "12) Discover/import existing GRE tunnels"
    echo "q) Quit"
    echo
    read -r -p "Select: " choice
    case "$choice" in
      0) precheck_gre ;;
      1) setup_tunnel ;;
      2) delete_tunnel ;;
      3) edit_tunnel ;;
      4) logs_menu ;;
      5) health_menu ;;
      6) show_details_menu ;;
