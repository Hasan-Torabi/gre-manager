usage() {
  cat <<EOF2
$APP_NAME v$APP_VERSION

Usage:
  gre-manager                 Interactive menu
  gre-manager --install       Install local/current script to $INSTALL_PATH
  gre-manager --update        Download latest script from GitHub and replace $INSTALL_PATH
  gre-manager --version       Show version
  gre-manager --up NAME       Bring managed tunnel up (used by systemd)
  gre-manager --down NAME     Bring managed tunnel down (used by systemd)
  gre-manager --watchdog NAME Watchdog check (used by systemd timer)
  gre-manager --list          List managed tunnel names
  gre-manager --discover      Show detected managed/runtime/legacy GRE tunnels
EOF2
}

case "${1:-}" in
  --install) install_manager ;;
  --update) self_update_manager ;;
  --version) echo "$APP_NAME v$APP_VERSION" ;;
  --up) require_root; ensure_dirs; [ -n "${2:-}" ] || { err "Missing tunnel name."; exit 1; }; bring_up_tunnel "$2" ;;
  --down) require_root; ensure_dirs; [ -n "${2:-}" ] || { err "Missing tunnel name."; exit 1; }; bring_down_tunnel "$2" ;;
  --watchdog) require_root; ensure_dirs; [ -n "${2:-}" ] || { err "Missing tunnel name."; exit 1; }; watchdog_check "$2" ;;
  --list) list_managed_tunnels ;;
  --discover) require_root; ensure_dirs; show_discovery_table ;;
  -h|--help) usage ;;
  "")
    if is_root && [ "$(readlink -f "${BASH_SOURCE[0]:-$0}" 2>/dev/null || true)" != "$(readlink -f "$INSTALL_PATH" 2>/dev/null || true)" ]; then
      install_manager >/dev/null 2>&1 || warn "Auto-install failed. You can still use this session, or run: gre-manager --install"
    fi
    main_menu
    ;;
  *) usage; exit 1 ;;
esac
