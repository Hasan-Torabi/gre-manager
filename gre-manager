rpfilter_menu() {
  while true; do
    menu_header
    echo "rp_filter management"
    echo
    echo "Recommended for GRE/multi-route setups: rp_filter=0 on the GRE interface."
    echo
    show_discovery_table || true
    echo
    local lines line source id tun current disabled
    mapfile -t lines < <(discover_tunnels)
    if [ "${#lines[@]}" -gt 0 ]; then
      echo; echo "Current rp_filter values:"
      for line in "${lines[@]}"; do
        source=$(line_get "$line" 0); id=$(line_get "$line" 1); tun=$(line_get "$line" 2)
        current=$(sysctl -n "net.ipv4.conf.$tun.rp_filter" 2>/dev/null || echo "not available")
        disabled="unknown"
        if [ "$source" = "managed" ] && load_config "$id" >/dev/null 2>&1; then disabled="$DISABLE_RPFILTER"; fi
        echo "  $tun: rp_filter=$current, manager_disable=$disabled"
      done
    fi
    echo
    echo "1) Set rp_filter=0 for a detected interface"
    echo "2) Set rp_filter=1 for a detected interface"
    echo "3) Set rp_filter=0 by custom interface name"
    echo "4) Set all.rp_filter=0"
    echo "0) Back"
    local c
    read -r -p "Select: " c
    case "$c" in
      1) choose_discovered_tunnel "Choose interface" || continue; line="$CHOSEN_LINE"; tun=$(line_get "$line" 2); source=$(line_get "$line" 0); id=$(line_get "$line" 1); sysctl -w "net.ipv4.conf.$tun.rp_filter=0" || true; sysctl -w net.ipv4.conf.all.rp_filter=0 || true; if [ "$source" = "managed" ]; then load_config "$id" && DISABLE_RPFILTER="yes" && write_config "$id"; fi; echo "rp_filter disabled for $tun."; pause ;;
      2) choose_discovered_tunnel "Choose interface" || continue; line="$CHOSEN_LINE"; tun=$(line_get "$line" 2); source=$(line_get "$line" 0); id=$(line_get "$line" 1); sysctl -w "net.ipv4.conf.$tun.rp_filter=1" || true; if [ "$source" = "managed" ]; then load_config "$id" && DISABLE_RPFILTER="no" && write_config "$id"; fi; echo "rp_filter set to 1 for $tun."; pause ;;
      3) read -r -p "Interface name: " tun; safe_name "$tun" && sysctl -w "net.ipv4.conf.$tun.rp_filter=0" && sysctl -w net.ipv4.conf.all.rp_filter=0 || echo "Invalid or unavailable interface."; pause ;;
      4) sysctl -w net.ipv4.conf.all.rp_filter=0 || true; echo "all.rp_filter set to 0."; pause ;;
      0) return 0 ;;
      *) echo "Invalid choice."; pause ;;
    esac
  done
}

