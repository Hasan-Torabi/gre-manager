    echo "MSS clamp management"
    echo
    show_mss_rules
    echo
    echo "Detected GRE interfaces:"
    show_discovery_table || true
    echo
    echo "1) Enable MSS clamp for a detected GRE interface"
    echo "2) Remove MSS clamp for a detected GRE interface"
    echo "3) Enable MSS clamp by custom interface name"
    echo "4) Remove MSS clamp by custom interface name"
    echo "5) Save iptables rules with netfilter-persistent"
    echo "0) Back"
    local c line tun source id
    read -r -p "Select: " c
    case "$c" in
      1) choose_discovered_tunnel "Choose interface" || continue; line="$CHOSEN_LINE"; tun=$(line_get "$line" 2); apply_mss_clamp_rules "$tun"; source=$(line_get "$line" 0); id=$(line_get "$line" 1); if [ "$source" = "managed" ]; then load_config "$id" && MSS_CLAMP="yes" && write_config "$id"; fi; echo "MSS clamp enabled for $tun."; pause ;;
      2) choose_discovered_tunnel "Choose interface" || continue; line="$CHOSEN_LINE"; tun=$(line_get "$line" 2); remove_mss_clamp_rules "$tun"; source=$(line_get "$line" 0); id=$(line_get "$line" 1); if [ "$source" = "managed" ]; then load_config "$id" && MSS_CLAMP="no" && write_config "$id"; fi; echo "MSS clamp removed for $tun."; pause ;;
      3) read -r -p "Interface name: " tun; safe_name "$tun" && apply_mss_clamp_rules "$tun" && echo "MSS clamp enabled for $tun." || echo "Invalid interface name."; pause ;;
      4) read -r -p "Interface name: " tun; safe_name "$tun" && remove_mss_clamp_rules "$tun" && echo "MSS clamp removed for $tun." || echo "Invalid interface name."; pause ;;
      5) save_firewall_if_possible; echo "Saved if netfilter-persistent is installed."; pause ;;
